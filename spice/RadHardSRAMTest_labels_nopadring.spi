* testlib


* Device subcircuits
*
.subckt rsil n1 n2 l=1e-6 w=1e-6
.param rsil_res={l*7.0/w}
Rres n1 n2 r={rsil_res} rsil l=l w=w
.ends rsil

.subckt rppd n1 n2 l=1e-6 w=1e-6
.param rppd_res={l*260.0/w}
Rres n1 n2 r={rppd_res} rppd l=l w=w
.ends rppd

.subckt dantenna an cat params: w=0.48e-6 l=0.48e-6
Ddio an cat dantenna a=(w*l) p=(2*(w + l))
.ends dantenna

.subckt dpantenna an cat params: w=0.48e-6 l=0.48e-6
Ddio an cat dpantenna a=(w*l) p=(2*(w + l))
.ends dpantenna

.subckt sg13_lv_nmos s g d b params: l=0.13e-6 w=0.15e-6
Mtrans s g d b sg13_lv_nmos l=l w=w
.ends sg13_lv_nmos

.subckt sg13_lv_pmos s g d b params: l=0.13e-6 w=0.15e-6
Mtrans s g d b sg13_lv_pmos l=l w=w
.ends sg13_lv_pmos

.subckt sg13_hv_nmos s g d b params: l=0.45e-6 w=0.3e-6
Mtrans s g d b sg13_hv_nmos l=l w=w
.ends sg13_hv_nmos

.subckt sg13_hv_pmos s g d b params: l=0.45e-6 w=0.3e-6
Mtrans s g d b sg13_hv_pmos l=l w=w
.ends sg13_hv_pmos

* Library cells
*
.subckt BondPad pad
.ends BondPad

.subckt sg13g2_IOPadIn pad p2c
.ends sg13g2_IOPadIn

.subckt sg13g2_IOPadOut30mA pad c2p
.ends sg13g2_IOPadOut30mA

.subckt sg13g2_IOPadAnalog pad pad_core
.ends sg13g2_IOPadAnalog

.subckt sg13g2_Corner 
.ends sg13g2_Corner

.subckt sg13g2_Filler2000 
.ends sg13g2_Filler2000

.subckt sg13g2_Filler4000 
.ends sg13g2_Filler4000

.subckt sg13g2_Filler10000 
.ends sg13g2_Filler10000

.subckt sg13g2_Filler20000 
Xfill1  sg13g2_Filler10000
Xfill2  sg13g2_Filler10000
.ends sg13g2_Filler20000

.subckt sg13g2_IOPadVss pad
.ends sg13g2_IOPadVss

.subckt sg13g2_IOPadVdd pad
.ends sg13g2_IOPadVdd

.subckt sg13g2_IOPadIOVss pad
.ends sg13g2_IOPadIOVss

.subckt sg13g2_IOPadIOVdd pad
.ends sg13g2_IOPadIOVdd

.subckt sg13g2_DCIO10000 vss vdd iovss iovdd
Xbp_vss vss BondPad
Xio_vss vss sg13g2_IOPadVss
Xbp_vdd vdd BondPad
Xio_vdd vdd sg13g2_IOPadVdd
Xbp_iovss iovss BondPad
Xio_iovss iovss sg13g2_IOPadIOVss
Xbp_iovdd iovdd BondPad
Xio_iovdd iovdd sg13g2_IOPadIOVdd
Xfill_start  sg13g2_Filler10000
Xfill_vss  sg13g2_Filler10000
Xfill_vdd  sg13g2_Filler10000
Xfill_iovss  sg13g2_Filler10000
Xfill_iovdd  sg13g2_Filler10000
.ends sg13g2_DCIO10000

.subckt SP6T1Cell vss substrate vdd nwell wl bl bl_n
Xpu1 vdd bit_n bit nwell sg13_lv_pmos l=1.3e-07 w=1.5e-07
Xpd1 bit bit_n vss substrate sg13_lv_nmos l=1.3e-07 w=2e-07
Xpu2 vdd bit bit_n nwell sg13_lv_pmos l=1.3e-07 w=1.5e-07
Xpd2 bit_n bit vss substrate sg13_lv_nmos l=1.3e-07 w=2e-07
Xpg1 bit wl bl substrate sg13_lv_nmos l=1.3e-07 w=2e-07
Xpg2 bit_n wl bl_n substrate sg13_lv_nmos l=1.3e-07 w=2e-07
.ends SP6T1Cell

